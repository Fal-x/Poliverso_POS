  Organization {
    string id PK
    string name
    string legalName
    string nit
  }
  Site {
    string id PK
    string organizationId FK
    string code
    string name
    string status
    string timezone
  }
  SiteConfig {
    string id PK
    string siteId FK
    decimal minRechargeAmount
    int pointsPerCurrency
    int currencyUnit
  }
  Role {
    string id PK
    string name
  }
  RolePermission {
    string id PK
    string roleId FK
    string permission
  }
  User {
    string id PK
    string email
    string fullName
    string status
  }
  UserAssignment {
    string id PK
    string userId FK
    string siteId FK
    string roleId FK
    bool isActive
  }
  UserAuthCode {
    string id PK
    string userId FK
    datetime expiresAt
  }
